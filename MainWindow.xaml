<Window x:Class="LinkShelf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="760"
        Width="1160"
        MinHeight="620"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="190" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#D9DEE7"
                BorderThickness="0,0,0,1"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="CacheRootText"
                               Margin="0,8,0,0"
                               Foreground="#60656F"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="ConfigText"
                               Margin="0,4,0,0"
                               Foreground="#60656F"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Column="1"
                      VerticalAlignment="Top"
                      HorizontalAlignment="Right">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,12">
                        <TextBlock x:Name="LanguageLabel"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox x:Name="LanguageSelector"
                                  Width="140"
                                  Height="32"
                                  SelectionChanged="LanguageSelector_SelectionChanged">
                            <ComboBoxItem Tag="en" />
                            <ComboBoxItem Tag="zh" />
                        </ComboBox>
                    </StackPanel>

                    <WrapPanel Grid.Row="1"
                               HorizontalAlignment="Right">
                        <Button x:Name="AddSyncButton"
                                Width="118"
                                Height="34"
                                ToolTipService.InitialShowDelay="250"
                                ToolTipService.ShowDuration="12000"
                                MouseEnter="AddSyncButton_MouseEnter"
                                Click="AddSyncButton_Click">
                            <Button.ContextMenu>
                                <ContextMenu x:Name="AddSyncMenu">
                                    <MenuItem x:Name="AddDirectoryMenuItem"
                                              Click="AddDirectoryMenuItem_Click" />
                                    <MenuItem x:Name="AddFileMenuItem"
                                              Click="AddFileMenuItem_Click" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>

                        <Button x:Name="RestoreButton"
                                Width="120"
                                Height="34"
                                Margin="6,0,0,0"
                                ToolTipService.InitialShowDelay="250"
                                ToolTipService.ShowDuration="12000"
                                Click="RestoreButton_Click" />

                        <Button x:Name="CheckButton"
                                Width="110"
                                Height="34"
                                Margin="6,0,0,0"
                                ToolTipService.InitialShowDelay="250"
                                ToolTipService.ShowDuration="12000"
                                Click="CheckButton_Click" />

                        <Button x:Name="UnsyncButton"
                                Width="110"
                                Height="34"
                                Margin="6,0,0,0"
                                ToolTipService.InitialShowDelay="250"
                                ToolTipService.ShowDuration="12000"
                                Click="UnsyncButton_Click" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="18">
            <DataGrid x:Name="ItemsGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      Background="#FFFFFF"
                      BorderBrush="#D9DEE7"
                      BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="CacheNameColumn"
                                        Binding="{Binding CacheName}"
                                        Width="170" />
                    <DataGridTextColumn x:Name="OriginalPathColumn"
                                        Binding="{Binding OriginalPath}"
                                        Width="260" />
                    <DataGridTextColumn x:Name="TypeColumn"
                                        Binding="{Binding ItemType}"
                                        Width="80" />
                    <DataGridTextColumn x:Name="StatusColumn"
                                        Binding="{Binding Status}"
                                        Width="80" />
                    <DataGridTextColumn x:Name="CheckResultColumn"
                                        Binding="{Binding CheckResult}"
                                        Width="150" />
                    <DataGridTextColumn x:Name="SourceMachineColumn"
                                        Binding="{Binding SourceMachine}"
                                        Width="130" />
                    <DataGridTextColumn x:Name="LastOperationColumn"
                                        Binding="{Binding LastOperation}"
                                        Width="150" />
                    <DataGridTextColumn x:Name="UpdatedAtColumn"
                                        Binding="{Binding UpdatedAt}"
                                        Width="150" />
                    <DataGridTextColumn x:Name="CachePathColumn"
                                        Binding="{Binding CachePath}"
                                        Width="260" />
                    <DataGridTextColumn x:Name="LocalTargetColumn"
                                        Binding="{Binding ExpandedOriginalPath}"
                                        Width="260" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D9DEE7"
                BorderThickness="0,1,0,0"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="LogTitleText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="#FAFAFA"
                         BorderBrush="#D9DEE7" />
            </Grid>
        </Border>
    </Grid>
</Window>
