<Window x:Class="LinkShelf.LockingProcessesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="640"
        Width="980"
        MinHeight="520"
        MinWidth="820"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#F5F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#D9DEE7"
                BorderThickness="0,0,0,1"
                Padding="16">
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="PathText"
                           Margin="0,8,0,0"
                           Foreground="#60656F"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="ErrorText"
                           Margin="0,4,0,0"
                           Foreground="#9A3412"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#D9DEE7"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <ProgressBar x:Name="Progress"
                             Height="22"
                             IsIndeterminate="True" />
                <TextBlock x:Name="StatusText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="220" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="ProcessGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionUnit="FullRow"
                      Background="#FFFFFF"
                      BorderBrush="#D9DEE7"
                      BorderThickness="1"
                      SelectionChanged="ProcessGrid_SelectionChanged">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="TerminateSelectedMenuItem"
                                  Click="TerminateSelectedMenuItem_Click" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="ProcessNameColumn"
                                        Binding="{Binding ProcessName}"
                                        Width="180" />
                    <DataGridTextColumn x:Name="ProcessIdColumn"
                                        Binding="{Binding ProcessId}"
                                        Width="90" />
                    <DataGridTextColumn x:Name="UserColumn"
                                        Binding="{Binding UserName}"
                                        Width="170" />
                    <DataGridTextColumn x:Name="ExecutableColumn"
                                        Binding="{Binding ExecutablePath}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <TextBox x:Name="LockedFilesBox"
                     Grid.Row="2"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     Background="#FFFFFF"
                     BorderBrush="#D9DEE7" />
        </Grid>

        <Border Grid.Row="3"
                Background="#FFFFFF"
                BorderBrush="#D9DEE7"
                BorderThickness="0,1,0,0"
                Padding="16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="RefreshButton"
                        Width="110"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RefreshButton_Click" />
                <Button x:Name="TerminateAllAndContinueButton"
                        Width="190"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="TerminateAllAndContinueButton_Click" />
                <Button x:Name="CancelButton"
                        Width="92"
                        Height="34"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
