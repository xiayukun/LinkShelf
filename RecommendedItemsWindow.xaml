<Window x:Class="LinkShelf.RecommendedItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="560"
        Width="940"
        MinHeight="420"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#F5F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#FFFFFF"
                BorderBrush="#D9DEE7"
                BorderThickness="0,0,0,1"
                Padding="18">
            <StackPanel>
                <TextBlock x:Name="HeadingText"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="DescriptionText"
                           Margin="0,8,0,0"
                           Foreground="#60656F"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <DataGrid x:Name="RecommendedGrid"
                  Grid.Row="1"
                  Margin="18"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="#FFFFFF"
                  BorderBrush="#D9DEE7"
                  BorderThickness="1"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn x:Name="SelectColumn"
                                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                        Width="70" />
                <DataGridTextColumn x:Name="NameColumn"
                                    Binding="{Binding Name}"
                                    IsReadOnly="True"
                                    Width="170" />
                <DataGridTextColumn x:Name="PathColumn"
                                    Binding="{Binding PortablePath}"
                                    IsReadOnly="True"
                                    Width="250" />
                <DataGridTextColumn x:Name="TypeColumn"
                                    Binding="{Binding ItemType}"
                                    IsReadOnly="True"
                                    Width="90" />
                <DataGridTemplateColumn x:Name="ReasonColumn"
                                        IsReadOnly="True"
                                        MinWidth="260"
                                        Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Reason}"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       Padding="4,2"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D9DEE7"
                BorderThickness="0,1,0,0"
                Padding="18">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="AddSelectedButton"
                        Width="150"
                        Height="34"
                        Click="AddSelectedButton_Click" />
                <Button x:Name="CancelButton"
                        Width="110"
                        Height="34"
                        Margin="10,0,0,0"
                        Click="CancelButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
